{
    "name": "@workspace/api",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "dev": "node --require ts-node/register src/index.ts",
        "watch": "nodemon src/index.ts --exec \"node --require ts-node/register\"",
        "build": "tsc",
        "start": "node dist/index.js",
        "start:built": "npm run build && node dist/index.js",
        "lint": "eslint \"src/**/*.ts*\"",
        "seed": "node --require ts-node/register src/seed.ts"
    },
    "dependencies": {
        "bcrypt": "^6.0.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.18.2",
        "express-mongo-sanitize": "^2.2.0",
        "express-rate-limit": "^8.3.1",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^8.2.1",
        "nodemailer": "^8.0.2",
        "openai": "^6.29.0",
        "socket.io": "^4.8.3",
        "winston": "^3.19.0",
        "xss-clean": "^0.1.4",
        "zod": "^3.24.1",
        "@types/bcrypt": "^6.0.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^20.11.24",
        "@types/nodemailer": "^7.0.11",
        "typescript": "^5.3.3"
    },
    "devDependencies": {
        "eslint": "^8.57.0",
        "nodemon": "^3.1.0",
        "ts-node": "^10.9.2"
    }
}